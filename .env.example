# ─── AURA SDK — Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Core: Google AI (required for AURA agent brain)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot (required for live Telegram integration)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter (optional fallback LLM for content rewriting)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Airtable (required for content pipeline — save drafts)
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_NAME=Content Station

# Web Search (optional — SerpAPI for research crew)
SERPAPI_KEY=your_serpapi_key_here

# Image Generation (optional — Replicate for Flux image gen)
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Branding defaults
DEFAULT_BRAND=Sakluma
BOSS_NAME=Matrol
BOSS_CHAT_ID=your_telegram_chat_id_here

# APIFY
APIFY_API_TOKEN=
